# HLEcosystem — Production Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=foxxlab_admin
POSTGRES_PASSWORD=          # REQUIRED — set a strong password

# ── SSO Authentication ────────────────────────────────────
# AUTH_URL is the public URL of Family Manager (the SSO provider).
# AUTH_DOMAIN is the cookie domain for shared sessions (e.g., .zulupf.com).
# All app URLs must be set so SSO redirects work correctly.
AUTH_URL=https://manager.zulupf.com
AUTH_DOMAIN=.zulupf.com
SECURE_COOKIES=true

# ── App URLs (public-facing, used for SSO redirects) ──────
HUB_URL=https://hub.zulupf.com
FINANCE_URL=https://finance.zulupf.com
HEALTH_URL=https://health.zulupf.com
HOMECARE_URL=https://homecare.zulupf.com
FILES_URL=https://files.zulupf.com
MEALS_URL=https://meals.zulupf.com
WIKI_URL=https://wiki.zulupf.com

# ── Port Overrides (optional, defaults shown) ─────────────
# FM_PORT=8080              # Family Manager
# HUB_PORT=8081             # FamilyHub
# FINANCE_PORT=8082         # Family Finance
# HEALTH_PORT=8083          # Family Health
# HOMECARE_PORT=8084        # Home Care
# FILES_PORT=8085           # File Server
# MEALS_PORT=8086           # Meal Prep
# WIKI_PORT=8087            # Family Wiki
