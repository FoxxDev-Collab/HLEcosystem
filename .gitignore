# ============================================
# HLEcosystem .gitignore (Next.js monorepo + Podman)
# ============================================

# Dependencies
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
**/.next/
**/out/
**/build/
*.tsbuildinfo
next-env.d.ts

# Prisma generated client (if outputted to a local dir)
**/prisma/generated/

# Environment files (NEVER commit)
.env
.env.*
!.env.example
!.env.*.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
*.lcov
.nyc_output/

# Editors / IDEs
.vscode/
!.vscode/extensions.json
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Podman / Docker overrides
compose.override.yaml
**/docker-compose*.override.yml

# Podman volumes + database backups
volumes/
backups/

# Temp
*.tmp
*.temp
*.bak
*.cache

# Claude Code local settings (do not commit personal MCP config)
**/.claude/settings.local.json
.mcp.json

# Archived legacy codebase (not part of the Next.js ecosystem)
HLEcosystem_Dotnet_Backup/

# User-uploaded runtime data (never source)
**/Data/uploads/
**/Data/group_files/
**/TaxDocuments/
**/uploads/
