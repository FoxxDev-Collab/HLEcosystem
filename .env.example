# HLEcosystem environment variables
# Copy to .env and fill in values:
#   cp .env.example .env

POSTGRES_USER=
POSTGRES_PASSWORD=

# ── First-run admin seed (only used when database is empty) ──
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
HOUSEHOLD_NAME=

# ── SSO (optional for local dev, required for production) ──
