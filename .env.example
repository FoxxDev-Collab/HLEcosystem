# HUB_URL=
# FINANCE_URL=
# HEALTH_URL=
# HOMECARE_URL=
# FILES_URL=
# MEALS_URL=
# WIKI_URL=

# ── Claude API Gateway ──
ANTHROPIC_API_KEY=
CLAUDE_API_SERVICE_SECRET=
