# Containerfile.nextjs
# Shared multi-stage build for all HLEcosystem Next.js apps with Prisma.
#
# Build arg APP_DIR specifies which app to build.
# Usage: podman-compose build hle-familyhub
#
# Stages:
#   1. deps       — install ALL deps (prod + dev), needed by the builder stage
#                   for `next build` (which requires typescript, eslint, tailwind,
#                   vitest, etc.)
#   2. builder    — produces the Next.js standalone output
#   3. prod-deps  — CLEAN install of ONLY prod deps. This is what ships to the
#                   runtime image. Keeps vitest/vite/esbuild (Go binary) and
#                   other dev-only surfaces out of the production attack
#                   surface. Prisma CLI stays because it is a prod dep in every
#                   app (verified 2026-04-09).
#   4. runner     — minimal runtime, non-root, apk upgrade for base CVEs

ARG APP_DIR=.

# ============================================
# Stage 1: Install all dependencies (build-time)
# ============================================
FROM node:22-alpine AS deps
ARG APP_DIR
WORKDIR /app

COPY ${APP_DIR}/package.json ${APP_DIR}/package-lock.json ./
COPY ${APP_DIR}/prisma ./prisma/

RUN npm ci --ignore-scripts && \
    npx prisma generate && \
    # Rebuild native modules (sharp, etc.) if present
    npm rebuild 2>/dev/null || true

# ============================================
# Stage 2: Build the application
# ============================================
FROM node:22-alpine AS builder
ARG APP_DIR
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY ${APP_DIR} .

COPY --from=deps /app/node_modules/.prisma ./node_modules/.prisma

ARG NEXT_PUBLIC_APP_NAME="HLEcosystem App"
ENV NEXT_PUBLIC_APP_NAME=${NEXT_PUBLIC_APP_NAME}
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# ============================================
# Stage 3: Production-only dependency install
# ============================================
# Separate, clean `npm ci --omit=dev` — never imports dev deps.
# This is what the runtime image COPYs, so vitest, vite, esbuild (Go),
# eslint, typescript, @vitest/coverage-v8, tailwind CLI, tsx, etc. do
# not end up on disk in the runner image and cannot be scanned as CVEs.
FROM node:22-alpine AS prod-deps
ARG APP_DIR
WORKDIR /app

COPY ${APP_DIR}/package.json ${APP_DIR}/package-lock.json ./
COPY ${APP_DIR}/prisma ./prisma/

RUN npm ci --omit=dev --ignore-scripts && \
    npx prisma generate

# ============================================
# Stage 4: Production runtime (minimal)
# ============================================
FROM node:22-alpine AS runner
WORKDIR /app

# Apply all pending apk security updates on top of the base image.
# node:22-alpine base was shipping zlib 1.3.1-r2 which is affected by
# CVE-2026-22184 (HIGH). Upgrading here catches any similar base-image
# CVE that lands before the base-image maintainers rebuild.
# Must run as root — happens before the USER nextjs directive below.
RUN apk upgrade --no-cache

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Prod-only node_modules from the dedicated prod-deps stage — NOT from
# the builder stage, which would leak dev deps (vitest/esbuild/etc.)
# into the runtime image.
COPY --from=prod-deps /app/node_modules ./node_modules

# Prisma schema + migrations for entrypoint migrate deploy
COPY --from=builder /app/prisma ./prisma/

COPY --from=builder --chown=nextjs:nodejs /app/entrypoint.sh ./entrypoint.sh
RUN chmod +x entrypoint.sh

# Uploads directory for apps with file storage (volume-mounted in compose)
RUN mkdir -p /app/uploads && chown nextjs:nodejs /app/uploads

USER nextjs
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000/api/health || exit 1

CMD ["./entrypoint.sh"]
